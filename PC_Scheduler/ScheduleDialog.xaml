<Window x:Class="PCScheduler.ScheduleDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Расписание"
        Width="400"
        Height="380"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="120" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Label Grid.Row="0" Grid.Column="0" Content="Тип:" />
        <ComboBox Grid.Row="0" Grid.Column="1" x:Name="TypeCombo" Margin="4" SelectedIndex="0">
            <ComboBoxItem Content="Сон (Sleep)" Tag="Sleep" />
            <ComboBoxItem Content="Пробуждение (Wake)" Tag="Wake" />
        </ComboBox>

        <Label Grid.Row="1" Grid.Column="0" Content="Время:" />
        <TextBox Grid.Row="1" Grid.Column="1" x:Name="TimeBox" Margin="4" Text="08:00" VerticalContentAlignment="Center" />

        <Label Grid.Row="2" Grid.Column="0" Content="Повтор:" />
        <ComboBox Grid.Row="2" Grid.Column="1" x:Name="RepeatCombo" Margin="4" SelectedIndex="0" SelectionChanged="RepeatCombo_SelectionChanged">
            <ComboBoxItem Content="Ежедневно" Tag="Daily" />
            <ComboBoxItem Content="По будням" Tag="Weekdays" />
            <ComboBoxItem Content="Еженедельно" Tag="Weekly" />
            <ComboBoxItem Content="Один раз" Tag="Once" />
        </ComboBox>

        <Label Grid.Row="3" Grid.Column="0" Content="Дни недели:" />
        <WrapPanel Grid.Row="3" Grid.Column="1" x:Name="DaysPanel" Margin="4" IsEnabled="False">
            <CheckBox x:Name="MonCb" Content="Пн" Margin="2" />
            <CheckBox x:Name="TueCb" Content="Вт" Margin="2" />
            <CheckBox x:Name="WedCb" Content="Ср" Margin="2" />
            <CheckBox x:Name="ThuCb" Content="Чт" Margin="2" />
            <CheckBox x:Name="FriCb" Content="Пт" Margin="2" />
            <CheckBox x:Name="SatCb" Content="Сб" Margin="2" />
            <CheckBox x:Name="SunCb" Content="Вс" Margin="2" />
        </WrapPanel>

        <CheckBox Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2" x:Name="EnabledCb" Content="Включено" IsChecked="True" Margin="4,8,4,4" />

        <StackPanel Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="SaveBtn" Content="Сохранить" Click="SaveBtn_Click" Width="100" />
            <Button Content="Отмена" Click="CancelBtn_Click" Width="100" Margin="8,4,4,4" />
        </StackPanel>
    </Grid>
</Window>
