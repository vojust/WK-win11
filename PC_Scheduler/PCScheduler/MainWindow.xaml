<Window x:Class="PCScheduler.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PCScheduler"
        Width="750" Height="520" MinWidth="600" MinHeight="400"
        WindowStartupLocation="CenterScreen"
        StateChanged="OnStateChanged" Closing="OnClosing">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" FontSize="20" FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}"
                   Margin="0,4,0,12" Text="Управление расписанием" />

        <DataGrid Grid.Row="1" x:Name="ScheduleGrid" IsReadOnly="True" AutoGenerateColumns="False"
                  SelectionMode="Single" SelectionChanged="OnSelectionChanged" Margin="0">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Тип" Binding="{Binding TypeDisplay}" Width="120" />
                <DataGridTextColumn Header="Время" Binding="{Binding TimeFormatted}" Width="80" />
                <DataGridTextColumn Header="Повтор" Binding="{Binding RepeatDisplay}" Width="*" />
                <DataGridTextColumn Header="Статус" Binding="{Binding StatusDisplay}" Width="50" />
                <DataGridTextColumn Header="Предупреждение" Binding="{Binding WarnDisplay}" Width="100" />
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,4">
            <Button x:Name="AddBtn" Content="+ Добавить" Click="OnAdd" Width="100" Margin="4" />
            <Button x:Name="EditBtn" Content="✏ Изменить" Click="OnEdit" Width="100" Margin="4" IsEnabled="False" />
            <Button x:Name="ToggleBtn" Content="Вкл/Выкл" Click="OnToggle" Width="85" Margin="4" IsEnabled="False" />
            <Button x:Name="DeleteBtn" Content="✖ Удалить" Click="OnDelete" Width="85" Margin="4" IsEnabled="False" />
            <Button x:Name="DeleteAllBtn" Content="🗑 Всё" Click="OnDeleteAll" Width="70" Margin="4" />
            <Button x:Name="TestWakeBtn" Content="Тест пробуждения" Click="OnTestWake" Width="130" Margin="4" />
            <Button x:Name="ApplyBtn" Content="Применить" Click="OnApply" Width="100" Margin="4" FontWeight="Bold"
                    Foreground="{StaticResource BgDark}" Background="{StaticResource AccentBrush}"
                    BorderBrush="{StaticResource AccentBrush}" />
        </StackPanel>

        <Border Grid.Row="3" BorderBrush="{StaticResource ControlBorder}" BorderThickness="0,1,0,0" Padding="0,6,0,0"
                Background="Transparent">
            <StackPanel Orientation="Horizontal">
                <TextBlock x:Name="StatusText" VerticalAlignment="Center" Margin="4"
                           Foreground="{StaticResource TextMuted}"
                           Text="Задач в планировщике: —" />
                <Button x:Name="StatusRefreshBtn" Content="🔄" Click="OnRefreshStatus" Width="30" Height="24"
                        Margin="4,0,0,0" Padding="2" ToolTip="Обновить статус" />
            </StackPanel>
        </Border>

        <Expander Grid.Row="4" Header="Лог" Margin="0,6,0,0" IsExpanded="False">
            <TextBox x:Name="LogBox" IsReadOnly="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                     Height="100" FontFamily="Consolas" FontSize="11"
                     Background="{StaticResource LogBg}" Foreground="{StaticResource LogText}" />
        </Expander>
    </Grid>
</Window>
