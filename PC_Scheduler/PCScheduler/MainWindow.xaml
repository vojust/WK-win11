<Window x:Class="PCScheduler.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Планировщик включения/выключения ПК"
        Width="700" Height="420" MinWidth="500" MinHeight="300"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" FontSize="18" FontWeight="SemiBold" Margin="4,8" Text="Управление расписанием" />

        <DataGrid Grid.Row="1" x:Name="ScheduleGrid" IsReadOnly="True" AutoGenerateColumns="False"
                  SelectionMode="Single" SelectionChanged="OnSelectionChanged" Margin="4">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Тип" Binding="{Binding TypeDisplay}" Width="120" />
                <DataGridTextColumn Header="Время" Binding="{Binding TimeFormatted}" Width="80" />
                <DataGridTextColumn Header="Повтор" Binding="{Binding RepeatDisplay}" Width="*" />
                <DataGridTextColumn Header="Статус" Binding="{Binding StatusDisplay}" Width="60" />
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="4,8">
            <Button x:Name="AddBtn" Content="+ Добавить" Click="OnAdd" Width="110" Margin="4" Padding="8,4" />
            <Button x:Name="EditBtn" Content="✏ Изменить" Click="OnEdit" Width="110" Margin="4" Padding="8,4" IsEnabled="False" />
            <Button x:Name="ToggleBtn" Content="Вкл/Выкл" Click="OnToggle" Width="90" Margin="4" Padding="8,4" IsEnabled="False" />
            <Button x:Name="DeleteBtn" Content="✖ Удалить" Click="OnDelete" Width="90" Margin="4" Padding="8,4" IsEnabled="False" />
            <Button x:Name="DeleteAllBtn" Content="🗑 Всё" Click="OnDeleteAll" Width="80" Margin="4" Padding="8,4" />
            <Button x:Name="ApplyBtn" Content="Применить" Click="OnApply" Width="110" Margin="4" Padding="8,4" FontWeight="Bold" />
        </StackPanel>
    </Grid>
</Window>
