<Window x:Class="PCScheduler.ScheduleDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Добавить задачу" Width="400" Height="360"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Label Grid.Row="0" Content="Тип" FontWeight="SemiBold" Foreground="{StaticResource TextMuted}" />
        <ComboBox Grid.Row="0" x:Name="TypeCombo" Margin="0,0,0,10" HorizontalAlignment="Right" Width="280"
                  SelectedIndex="0">
            <ComboBoxItem Content="Выключение (сон)" />
            <ComboBoxItem Content="Выключение (гибернация)" />
            <ComboBoxItem Content="Включение (пробуждение из сна)" />
        </ComboBox>

        <Label Grid.Row="1" Content="Время" FontWeight="SemiBold" Foreground="{StaticResource TextMuted}" />
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,10" Width="280">
            <ComboBox x:Name="HourCombo" Width="120" IsEditable="True" Text="08" />
            <TextBlock Text=":" Margin="8,0" VerticalAlignment="Center" FontSize="18" FontWeight="Bold"
                       Foreground="{StaticResource AccentBrush}" />
            <ComboBox x:Name="MinCombo" Width="120" IsEditable="True" Text="00" />
        </StackPanel>

        <Label Grid.Row="2" Content="Повторение" FontWeight="SemiBold" Foreground="{StaticResource TextMuted}" />
        <ComboBox Grid.Row="2" x:Name="RepeatCombo" Margin="0,0,0,10" HorizontalAlignment="Right" Width="280"
                  SelectionChanged="OnRepeatChanged">
            <ComboBoxItem Content="Ежедневно" />
            <ComboBoxItem Content="По будням" />
            <ComboBoxItem Content="Еженедельно" />
            <ComboBoxItem Content="Один раз" />
        </ComboBox>

        <GroupBox Grid.Row="3" Header="Дни недели" x:Name="DaysGroup" Visibility="Hidden"
                  Margin="0,0,0,10" Foreground="{StaticResource AccentBrush}" BorderBrush="{StaticResource ControlBorder}">
            <WrapPanel Margin="4">
                <CheckBox x:Name="MonCb" Content="Пн" Margin="4" />
                <CheckBox x:Name="TueCb" Content="Вт" Margin="4" />
                <CheckBox x:Name="WedCb" Content="Ср" Margin="4" />
                <CheckBox x:Name="ThuCb" Content="Чт" Margin="4" />
                <CheckBox x:Name="FriCb" Content="Пт" Margin="4" />
                <CheckBox x:Name="SatCb" Content="Сб" Margin="4" />
                <CheckBox x:Name="SunCb" Content="Вс" Margin="4" />
            </WrapPanel>
        </GroupBox>

        <CheckBox Grid.Row="4" x:Name="WarnCb" Content="Предупреждать за 5 минут до выключения"
                  Margin="0,0,0,10" Foreground="{StaticResource TextMuted}" />

        <Button Grid.Row="6" Content="Сохранить" Click="OnSave" IsDefault="True" Height="34" Width="120"
                HorizontalAlignment="Right" Margin="0,8,0,0"
                Foreground="{StaticResource BgDark}" Background="{StaticResource AccentBrush}"
                BorderBrush="{StaticResource AccentBrush}" FontWeight="SemiBold" FontSize="14" />
    </Grid>
</Window>
