<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Colors -->
    <Color x:Key="BgDark">#1e1e1e</Color>
    <Color x:Key="BgSurface">#2d2d2d</Color>
    <Color x:Key="BgControl">#333333</Color>
    <Color x:Key="BgHover">#3a3a3a</Color>
    <Color x:Key="BgSelected">#404040</Color>
    <Color x:Key="BorderColor">#444444</Color>
    <Color x:Key="FgPrimary">#e0e0e0</Color>
    <Color x:Key="FgSecondary">#9e9e9e</Color>
    <Color x:Key="Accent">#4fc3f7</Color>
    <Color x:Key="AccentDark">#0288d1</Color>
    <Color x:Key="AccentHover">#29b6f6</Color>
    <Color x:Key="Danger">#ef5350</Color>
    <Color x:Key="Success">#66bb6a</Color>

    <!-- Brushes -->
    <SolidColorBrush x:Key="WindowBg" Color="{StaticResource BgDark}" />
    <SolidColorBrush x:Key="SurfaceBg" Color="{StaticResource BgSurface}" />
    <SolidColorBrush x:Key="ControlBg" Color="{StaticResource BgControl}" />
    <SolidColorBrush x:Key="ControlBorder" Color="{StaticResource BorderColor}" />
    <SolidColorBrush x:Key="TextFg" Color="{StaticResource FgPrimary}" />
    <SolidColorBrush x:Key="TextMuted" Color="{StaticResource FgSecondary}" />
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource Accent}" />
    <SolidColorBrush x:Key="AccentDarkBrush" Color="{StaticResource AccentDark}" />
    <SolidColorBrush x:Key="AccentHoverBrush" Color="{StaticResource AccentHover}" />
    <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource Danger}" />
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource Success}" />
    <SolidColorBrush x:Key="HeaderBg" Color="#252525" />
    <SolidColorBrush x:Key="RowHoverBg" Color="{StaticResource BgHover}" />
    <SolidColorBrush x:Key="RowSelectedBg" Color="{StaticResource BgSelected}" />
    <SolidColorBrush x:Key="LogBg" Color="#1a1a1a" />
    <SolidColorBrush x:Key="LogText" Color="#8bc34a" />

    <!-- Global defaults -->
    <Style TargetType="Window">
        <Setter Property="Background" Value="{StaticResource WindowBg}" />
        <Setter Property="Foreground" Value="{StaticResource TextFg}" />
        <Setter Property="FontFamily" Value="Segoe UI" />
        <Setter Property="FontSize" Value="13" />
    </Style>

    <Style TargetType="Label">
        <Setter Property="Foreground" Value="{StaticResource TextFg}" />
        <Setter Property="FontSize" Value="13" />
    </Style>

    <Style TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource TextFg}" />
    </Style>

    <Style TargetType="Border">
        <Setter Property="Background" Value="{StaticResource SurfaceBg}" />
    </Style>

    <!-- Button -->
    <Style TargetType="Button">
        <Setter Property="Background" Value="{StaticResource ControlBg}" />
        <Setter Property="Foreground" Value="{StaticResource TextFg}" />
        <Setter Property="BorderBrush" Value="{StaticResource ControlBorder}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="12,6" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="4"
                            SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Margin="{TemplateBinding Padding}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="{StaticResource BgHover}" />
                            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter Property="Background" Value="{StaticResource AccentDarkBrush}" />
                            <Setter Property="BorderBrush" Value="{StaticResource AccentDarkBrush}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.4" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- DataGrid -->
    <Style TargetType="DataGrid">
        <Setter Property="Background" Value="{StaticResource SurfaceBg}" />
        <Setter Property="Foreground" Value="{StaticResource TextFg}" />
        <Setter Property="BorderBrush" Value="{StaticResource ControlBorder}" />
        <Setter Property="RowBackground" Value="{StaticResource SurfaceBg}" />
        <Setter Property="AlternatingRowBackground" Value="{StaticResource ControlBg}" />
        <Setter Property="GridLinesVisibility" Value="Horizontal" />
        <Setter Property="HorizontalGridLinesBrush" Value="{StaticResource ControlBorder}" />
        <Setter Property="VerticalGridLinesBrush" Value="Transparent" />
        <Setter Property="HeadersVisibility" Value="Column" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="RowHeight" Value="32" />
    </Style>

    <Style TargetType="DataGridColumnHeader">
        <Setter Property="Background" Value="{StaticResource HeaderBg}" />
        <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource ControlBorder}" />
        <Setter Property="BorderThickness" Value="0,0,0,1" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Height" Value="34" />
        <Setter Property="HorizontalContentAlignment" Value="Left" />
        <Setter Property="Padding" Value="8,0" />
    </Style>

    <Style TargetType="DataGridCell">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{StaticResource TextFg}" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Padding" Value="8,0" />
    </Style>

    <Style TargetType="DataGridRow">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{StaticResource TextFg}" />
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{StaticResource RowHoverBg}" />
            </Trigger>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="{StaticResource RowSelectedBg}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- TextBox -->
    <Style TargetType="TextBox">
        <Setter Property="Background" Value="{StaticResource ControlBg}" />
        <Setter Property="Foreground" Value="{StaticResource TextFg}" />
        <Setter Property="BorderBrush" Value="{StaticResource ControlBorder}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="6,4" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="CaretBrush" Value="{StaticResource AccentBrush}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="4">
                        <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                        </Trigger>
                        <Trigger Property="IsFocused" Value="True">
                            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ComboBox -->
    <Style TargetType="ComboBox">
        <Setter Property="Background" Value="{StaticResource ControlBg}" />
        <Setter Property="Foreground" Value="{StaticResource TextFg}" />
        <Setter Property="BorderBrush" Value="{StaticResource ControlBorder}" />
        <Setter Property="Padding" Value="6,4" />
        <Setter Property="FontSize" Value="13" />
    </Style>

    <Style TargetType="ComboBoxItem">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{StaticResource TextFg}" />
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{StaticResource RowHoverBg}" />
                <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
            </Trigger>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="{StaticResource RowSelectedBg}" />
                <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- CheckBox -->
    <Style TargetType="CheckBox">
        <Setter Property="Foreground" Value="{StaticResource TextFg}" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Margin" Value="2" />
    </Style>

    <!-- Expander -->
    <Style TargetType="Expander">
        <Setter Property="Background" Value="{StaticResource SurfaceBg}" />
        <Setter Property="Foreground" Value="{StaticResource TextFg}" />
        <Setter Property="BorderBrush" Value="{StaticResource ControlBorder}" />
        <Setter Property="FontSize" Value="13" />
    </Style>

    <!-- GroupBox -->
    <Style TargetType="GroupBox">
        <Setter Property="Foreground" Value="{StaticResource TextFg}" />
        <Setter Property="BorderBrush" Value="{StaticResource ControlBorder}" />
        <Setter Property="FontSize" Value="13" />
    </Style>

    <!-- ScrollViewer -->
    <Style TargetType="ScrollViewer">
        <Setter Property="Background" Value="Transparent" />
    </Style>

    <!-- ScrollBar (basic dark) -->
    <Style TargetType="ScrollBar">
        <Setter Property="Background" Value="{StaticResource BgDark}" />
        <Setter Property="Foreground" Value="{StaticResource ControlBorder}" />
    </Style>

    <!-- ToolTip -->
    <Style TargetType="ToolTip">
        <Setter Property="Background" Value="{StaticResource SurfaceBg}" />
        <Setter Property="Foreground" Value="{StaticResource TextFg}" />
        <Setter Property="BorderBrush" Value="{StaticResource ControlBorder}" />
        <Setter Property="FontSize" Value="12" />
    </Style>

</ResourceDictionary>
